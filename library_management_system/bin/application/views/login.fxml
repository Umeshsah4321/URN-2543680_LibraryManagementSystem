<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="550.0" prefWidth="760.0"
	stylesheets="/application/application.css" styleClass="root"
	xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="application.controllers.loginController">

	<!-- Left side graphics (Optional styling placeholder to make it modern) -->
	<left>
		<VBox alignment="CENTER" prefWidth="300"
			style="-fx-background-color: linear-gradient(to bottom right, #3498db, #2c3e50);">
			<padding>
				<Insets top="40" right="20" bottom="40" left="20" />
			</padding>
			<Text text="Library"
				style="-fx-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" />
			<Text text="Management System"
				style="-fx-fill: #ecf0f1; -fx-font-size: 20px;" />
			<!-- Add a book icon here if available, otherwise just text -->
			<Label text="📚"
				style="-fx-font-size: 72px; -fx-text-fill: white; -fx-padding: 30 0 0 0;" />
		</VBox>
	</left>

	<!-- Right side login form -->
	<center>
		<VBox alignment="CENTER" spacing="30">
			<padding>
				<Insets top="40" right="40" bottom="40" left="40" />
			</padding>

			<VBox alignment="CENTER_LEFT" spacing="5">
				<Text text="Welcome Back!" styleClass="title-text" />
				<Label text="Please log in to your account." />
			</VBox>

			<VBox styleClass="card" spacing="15">
				<padding>
					<Insets top="30" right="30" bottom="30" left="30" />
				</padding>

				<VBox spacing="5">
					<Label text="Email Address" />
					<TextField fx:id="txtEmail" prefWidth="250"
						promptText="Enter registered email" />
				</VBox>

				<VBox spacing="5">
					<Label text="Password" />
					<PasswordField fx:id="txtPassword" prefWidth="250"
						promptText="Enter password" />
				</VBox>

				<Button fx:id="btnLogin" text="Login" prefWidth="250"
					onAction="#btnLoginAction" styleClass="btn-primary" />

				<HBox alignment="CENTER" spacing="5">
					<Label text="Don't have an account?" />
					<Button text="Register" styleClass="btn-secondary"
						style="-fx-padding: 2 5;" onAction="#switchToRegister" />
				</HBox>

				<Label fx:id="lblStatus" styleClass="status-label-error"
					wrapText="true" />
			</VBox>

		</VBox>
	</center>

</BorderPane>