<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane
	stylesheets="/application/application.css"
	styleClass="root"
	xmlns="http://javafx.com/javafx/21"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="application.controllers.studentDashboardController">

	<!-- ══════════ SIDEBAR ══════════ -->
	<left>
		<VBox styleClass="sidebar" spacing="8">
			<padding>
				<Insets top="32" right="20" bottom="24" left="20" />
			</padding>

			<VBox spacing="3" style="-fx-padding: 0 0 22 4;">
				<Label text="📖 LibraryPro" styleClass="sidebar-logo" />
				<Label text="Student Portal" styleClass="sidebar-subtitle" />
			</VBox>

			<Region styleClass="sidebar-divider" prefHeight="1"
				maxWidth="Infinity" />
			<Label text="MAIN MENU" styleClass="sidebar-section-label" />

			<Button fx:id="btnSideHome" text="⊞   Home" prefWidth="220"
				onAction="#showHome" styleClass="sidebar-btn" />
			<Button fx:id="btnSideSearch" text="🔍   Search Books"
				prefWidth="220" onAction="#showSearchBooks"
				styleClass="sidebar-btn" />
			<Button fx:id="btnSideBorrowed" text="📚   Borrowed Books"
				prefWidth="220" onAction="#showBorrowedBooks"
				styleClass="sidebar-btn" />
			<Button fx:id="btnSideFines" text="💳   Pay Fine" prefWidth="220"
				onAction="#showFines" styleClass="sidebar-btn" />
			<Button fx:id="btnSideAccount" text="👤   Account Status"
				prefWidth="220" onAction="#showAccountStatus"
				styleClass="sidebar-btn" />

			<Region VBox.vgrow="ALWAYS" />
			<Region styleClass="sidebar-divider" prefHeight="1"
				maxWidth="Infinity" />
			<VBox style="-fx-padding: 10 0 0 0;">
				<Button text="🚪   Logout" prefWidth="220" onAction="#logout"
					styleClass="btn-logout" />
			</VBox>
		</VBox>
	</left>

	<!-- ══════════ MAIN CONTENT ══════════ -->
	<center>
		<VBox VBox.vgrow="ALWAYS">
			<HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
				<Label fx:id="lblPageTitle" text="Home"
					styleClass="page-title-label" />
				<Region HBox.hgrow="ALWAYS" />
				<Label fx:id="lblTopUsername" text="📘 Student"
					styleClass="user-badge" />
			</HBox>

			<ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
				styleClass="scroll-pane" hbarPolicy="NEVER">
				<VBox styleClass="content-area" spacing="24">

					<!-- ─── HOME ─── -->
					<VBox fx:id="viewHome" managed="true" visible="true"
						spacing="22">

						<!-- Welcome Banner -->
						<VBox styleClass="welcome-banner" spacing="5">
							<Label fx:id="lblWelcome" text="Welcome back! 👋"
								styleClass="welcome-banner-title" />
							<Label
								text="Here is a summary of your library activity."
								styleClass="welcome-banner-sub" />
						</VBox>

						<!-- Stat Cards -->
						<HBox spacing="18">
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color:linear-gradient(to bottom right,#2563eb,#60a5fa);-fx-padding:28;">
								<Label fx:id="lblStatTotalBooks" text="—"
									styleClass="stat-number" />
								<Label text="Total Books"
									styleClass="stat-label" />
							</VBox>
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color:linear-gradient(to bottom right,#059669,#34d399);-fx-padding:28;">
								<Label fx:id="lblStatBorrowed" text="—"
									styleClass="stat-number" />
								<Label text="My Borrowed"
									styleClass="stat-label" />
							</VBox>
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color:linear-gradient(to bottom right,#d97706,#fbbf24);-fx-padding:28;">
								<Label fx:id="lblStatPending" text="—"
									styleClass="stat-number" />
								<Label text="Pending Returns"
									styleClass="stat-label" />
							</VBox>
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color:linear-gradient(to bottom right,#dc2626,#f87171);-fx-padding:28;">
								<Label fx:id="lblStatFines" text="—"
									styleClass="stat-number" />
								<Label text="Unpaid Fines"
									styleClass="stat-label" />
							</VBox>
						</HBox>

						<!-- Chart Row -->
						<HBox spacing="18">
							<!-- My Borrow Activity Pie -->
							<VBox styleClass="chart-card" HBox.hgrow="ALWAYS"
								spacing="4">
								<Label text="📊 My Book Status"
									styleClass="chart-title-label" />
								<Label
									text="Overview of your borrowed vs returned books"
									styleClass="card-subheader-label" />
								<PieChart fx:id="chartMyStatus" prefHeight="280"
									maxWidth="Infinity"
									legendVisible="true" labelsVisible="true" />
							</VBox>

							<!-- Library Collection Bar -->
							<VBox styleClass="chart-card" HBox.hgrow="ALWAYS"
								spacing="4">
								<Label text="📈 Library Overview"
									styleClass="chart-title-label" />
								<Label
									text="Available books vs books currently issued"
									styleClass="card-subheader-label" />
								<BarChart fx:id="chartLibraryOverview"
									prefHeight="280" maxWidth="Infinity"
									legendVisible="false" barGap="10"
									categoryGap="50">
									<xAxis>
										<CategoryAxis />
									</xAxis>
									<yAxis>
										<NumberAxis />
									</yAxis>
								</BarChart>
							</VBox>
						</HBox>

						<!-- Notifications -->
						<VBox styleClass="card" spacing="0">
							<HBox
								style="-fx-padding:18 24 14 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
								<Label text="🔔 Latest Notifications"
									styleClass="card-header-label" />
							</HBox>
							<VBox style="-fx-padding:12 24 22 24;">
								<TableView fx:id="tblNotifications"
									prefHeight="180" maxWidth="Infinity">
									<columns>
										<TableColumn text="Date" prefWidth="190">
											<cellValueFactory>
												<PropertyValueFactory
													property="createdAt" />
											</cellValueFactory>
										</TableColumn>
										<TableColumn text="Type" prefWidth="140">
											<cellValueFactory>
												<PropertyValueFactory
													property="type" />
											</cellValueFactory>
										</TableColumn>
										<TableColumn text="Message"
											prefWidth="900">
											<cellValueFactory>
												<PropertyValueFactory
													property="message" />
											</cellValueFactory>
										</TableColumn>
									</columns>
								</TableView>
							</VBox>
						</VBox>
					</VBox>

					<!-- ─── SEARCH BOOKS ─── -->
					<VBox fx:id="viewSearchBooks" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="🔍 Search Books"
									styleClass="card-header-label" />
								<Label
									text="Search by title or author and borrow available books"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="16" style="-fx-padding:16 24 24 24;">
							<HBox spacing="12" alignment="CENTER_LEFT">
								<TextField fx:id="txtSearch"
									promptText="🔍  Search by title or author..."
									HBox.hgrow="ALWAYS"
									style="-fx-padding: 11 14;" />
								<Button text="  Search  "
									onAction="#searchBooks"
									styleClass="btn-primary"
									style="-fx-padding:11 28;" />
							</HBox>
							<TableView fx:id="tblBooks" prefHeight="430"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="ID" prefWidth="65">
										<cellValueFactory>
											<PropertyValueFactory
												property="bookId" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Title" prefWidth="280">
										<cellValueFactory>
											<PropertyValueFactory
												property="title" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Author" prefWidth="200">
										<cellValueFactory>
											<PropertyValueFactory
												property="author" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Publisher"
										prefWidth="180">
										<cellValueFactory>
											<PropertyValueFactory
												property="publisher" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Year" prefWidth="80">
										<cellValueFactory>
											<PropertyValueFactory
												property="publicationYear" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Available"
										prefWidth="100">
										<cellValueFactory>
											<PropertyValueFactory
												property="availableCopies" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
							<HBox alignment="CENTER_RIGHT" spacing="14">
								<Label fx:id="lblSearchStatus"
									styleClass="status-label-success" />
								<Button text="📥 Borrow Selected Book"
									onAction="#borrowSelectedBook"
									styleClass="btn-success" />
							</HBox>
						</VBox>
					</VBox>

					<!-- ─── BORROWED BOOKS ─── -->
					<VBox fx:id="viewBorrowedBooks" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="📚 My Borrowed Books"
									styleClass="card-header-label" />
								<Label text="Books you currently have borrowed"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="16" style="-fx-padding:16 24 24 24;">
							<TableView fx:id="tblIssues" prefHeight="470"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="Issue ID" prefWidth="100">
										<cellValueFactory>
											<PropertyValueFactory
												property="issueId" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Book Title"
										prefWidth="380">
										<cellValueFactory>
											<PropertyValueFactory
												property="bookTitle" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Issue Date"
										prefWidth="200">
										<cellValueFactory>
											<PropertyValueFactory
												property="issueDate" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Status" prefWidth="160">
										<cellValueFactory>
											<PropertyValueFactory
												property="status" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
							<HBox alignment="CENTER_RIGHT" spacing="14">
								<Label fx:id="lblReturnStatus"
									styleClass="status-label-success" />
								<Button text="↩ Return Selected Book"
									onAction="#returnSelectedBook"
									styleClass="btn-primary" />
							</HBox>
						</VBox>
					</VBox>

					<!-- ─── FINES ─── -->
					<VBox fx:id="viewFines" styleClass="card" managed="false"
						visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="💳 My Fines"
									styleClass="card-header-label" />
								<Label
									text="Outstanding overdue fines on your account"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="16" style="-fx-padding:16 24 24 24;">
							<TableView fx:id="tblFines" prefHeight="450"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="Fine ID" prefWidth="120">
										<cellValueFactory>
											<PropertyValueFactory
												property="fineId" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Amount ($)"
										prefWidth="200">
										<cellValueFactory>
											<PropertyValueFactory
												property="amount" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Status" prefWidth="200">
										<cellValueFactory>
											<PropertyValueFactory
												property="status" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
							<HBox alignment="CENTER_RIGHT" spacing="14">
								<Label fx:id="lblFineStatus"
									styleClass="status-label-success" />
								<Button text="💳 Pay Selected Fine"
									onAction="#paySelectedFine"
									styleClass="btn-success" />
							</HBox>
						</VBox>
					</VBox>

					<!-- ─── ACCOUNT STATUS ─── -->
					<VBox fx:id="viewAccountStatus" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="👤 Account Status"
									styleClass="card-header-label" />
								<Label
									text="Your profile, borrowings and fines at a glance"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="22" style="-fx-padding:18 24 28 24;">
							<VBox styleClass="form-section" spacing="14">
								<Label text="PROFILE"
									styleClass="sidebar-section-label"
									style="-fx-padding:0;" />
								<HBox spacing="40">
									<VBox spacing="4">
										<Label text="Full Name"
											styleClass="form-label" />
										<Label fx:id="lblAccName" text="—"
											style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#0f172a;" />
									</VBox>
									<VBox spacing="4">
										<Label text="Email"
											styleClass="form-label" />
										<Label fx:id="lblAccEmail" text="—"
											style="-fx-font-size:14px;-fx-text-fill:#334155;" />
									</VBox>
									<VBox spacing="4">
										<Label text="Phone"
											styleClass="form-label" />
										<Label fx:id="lblAccPhone" text="—"
											style="-fx-font-size:14px;-fx-text-fill:#334155;" />
									</VBox>
									<VBox spacing="4">
										<Label text="Role"
											styleClass="form-label" />
										<Label fx:id="lblAccRole" text="—"
											style="-fx-font-size:14px;-fx-text-fill:#334155;" />
									</VBox>
								</HBox>
							</VBox>
							<VBox spacing="10">
								<Label text="ACTIVE BORROWINGS"
									styleClass="sidebar-section-label" />
								<TableView fx:id="tblAccIssues" prefHeight="220"
									maxWidth="Infinity">
									<columns>
										<TableColumn text="Book Title"
											prefWidth="400">
											<cellValueFactory>
												<PropertyValueFactory
													property="bookTitle" />
											</cellValueFactory>
										</TableColumn>
										<TableColumn text="Issue Date"
											prefWidth="200">
											<cellValueFactory>
												<PropertyValueFactory
													property="issueDate" />
											</cellValueFactory>
										</TableColumn>
										<TableColumn text="Status"
											prefWidth="180">
											<cellValueFactory>
												<PropertyValueFactory
													property="status" />
											</cellValueFactory>
										</TableColumn>
									</columns>
								</TableView>
							</VBox>
							<VBox spacing="10">
								<Label text="UNPAID FINES"
									styleClass="sidebar-section-label" />
								<TableView fx:id="tblAccFines" prefHeight="180"
									maxWidth="Infinity">
									<columns>
										<TableColumn text="Fine ID"
											prefWidth="120">
											<cellValueFactory>
												<PropertyValueFactory
													property="fineId" />
											</cellValueFactory>
										</TableColumn>
										<TableColumn text="Amount ($)"
											prefWidth="200">
											<cellValueFactory>
												<PropertyValueFactory
													property="amount" />
											</cellValueFactory>
										</TableColumn>
										<TableColumn text="Status"
											prefWidth="180">
											<cellValueFactory>
												<PropertyValueFactory
													property="status" />
											</cellValueFactory>
										</TableColumn>
									</columns>
								</TableView>
							</VBox>
						</VBox>
					</VBox>

				</VBox>
			</ScrollPane>
		</VBox>
	</center>
</BorderPane>
