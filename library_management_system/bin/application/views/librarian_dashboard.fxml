<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane
	stylesheets="/application/application.css"
	styleClass="root"
	xmlns="http://javafx.com/javafx/21"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="application.controllers.librarianDashboardController">

	<!-- ══════════ SIDEBAR ══════════ -->
	<left>
		<VBox styleClass="sidebar" spacing="8">
			<padding>
				<Insets top="32" right="20" bottom="24" left="20" />
			</padding>

			<VBox spacing="3" style="-fx-padding: 0 0 22 4;">
				<Label text="📖 LibraryPro" styleClass="sidebar-logo" />
				<Label text="Librarian Portal" styleClass="sidebar-subtitle" />
			</VBox>

			<Region styleClass="sidebar-divider" prefHeight="1"
				maxWidth="Infinity" />
			<Label text="MAIN MENU" styleClass="sidebar-section-label" />

			<Button fx:id="btnSideHome" text="⊞   Dashboard" prefWidth="220"
				onAction="#showHome" styleClass="sidebar-btn" />
			<Button fx:id="btnSideIssue" text="📋   Issue Book" prefWidth="220"
				onAction="#showIssueBook" styleClass="sidebar-btn" />
			<Button fx:id="btnSideBooks" text="📚   Manage Books"
				prefWidth="220" onAction="#showBookManage"
				styleClass="sidebar-btn" />
			<Button fx:id="btnSideMembers" text="👥   Manage Members"
				prefWidth="220" onAction="#showMemberManage"
				styleClass="sidebar-btn" />
			<Button fx:id="btnSideNotif" text="🔔   Notifications"
				prefWidth="220" onAction="#showNotifications"
				styleClass="sidebar-btn" />

			<Region VBox.vgrow="ALWAYS" />
			<Region styleClass="sidebar-divider" prefHeight="1"
				maxWidth="Infinity" />
			<VBox style="-fx-padding: 10 0 0 0;">
				<Button text="🚪   Logout" prefWidth="220" onAction="#logout"
					styleClass="btn-logout" />
			</VBox>
		</VBox>
	</left>

	<!-- ══════════ MAIN CONTENT ══════════ -->
	<center>
		<VBox VBox.vgrow="ALWAYS">
			<!-- Top Bar -->
			<HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
				<Label fx:id="lblPageTitle" text="Dashboard"
					styleClass="page-title-label" />
				<Region HBox.hgrow="ALWAYS" />
				<Label text="👤 Librarian" styleClass="user-badge" />
			</HBox>

			<!-- Scrollable Content -->
			<ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
				styleClass="scroll-pane" hbarPolicy="NEVER">
				<VBox styleClass="content-area" spacing="24">

					<!-- ─── HOME / DASHBOARD ─── -->
					<VBox fx:id="viewHome" managed="true" visible="true"
						spacing="22">

						<!-- Welcome Banner -->
						<VBox styleClass="welcome-banner" spacing="5">
							<Label text="Welcome back, Librarian! 👋"
								styleClass="welcome-banner-title" />
							<Label
								text="Here is your library overview for today."
								styleClass="welcome-banner-sub" />
						</VBox>

						<!-- Stat Cards Row -->
						<HBox spacing="18">
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color: linear-gradient(to bottom right,#2563eb,#60a5fa);-fx-padding:28;">
								<Label fx:id="lblStatTotalBooks" text="—"
									styleClass="stat-number" />
								<Label text="Total Books"
									styleClass="stat-label" />
							</VBox>
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color: linear-gradient(to bottom right,#059669,#34d399);-fx-padding:28;">
								<Label fx:id="lblStatActiveIssues" text="—"
									styleClass="stat-number" />
								<Label text="Active Issues"
									styleClass="stat-label" />
							</VBox>
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color: linear-gradient(to bottom right,#d97706,#fbbf24);-fx-padding:28;">
								<Label fx:id="lblStatMembers" text="—"
									styleClass="stat-number" />
								<Label text="Members" styleClass="stat-label" />
							</VBox>
							<VBox styleClass="stat-card" alignment="CENTER"
								spacing="8" HBox.hgrow="ALWAYS"
								style="-fx-background-color: linear-gradient(to bottom right,#dc2626,#f87171);-fx-padding:28;">
								<Label fx:id="lblStatUnpaidFines" text="—"
									styleClass="stat-number" />
								<Label text="Unpaid Fines"
									styleClass="stat-label" />
							</VBox>
						</HBox>

						<!-- Chart Row -->
						<HBox spacing="18">
							<!-- Pie Chart — Book Availability -->
							<VBox styleClass="chart-card" HBox.hgrow="ALWAYS"
								spacing="4">
								<Label text="📊 Book Availability Status"
									styleClass="chart-title-label" />
								<Label
									text="Distribution of available vs issued books"
									styleClass="card-subheader-label" />
								<PieChart fx:id="chartBookAvailability"
									prefHeight="280" maxWidth="Infinity"
									legendVisible="true" labelsVisible="true" />
							</VBox>

							<!-- Bar Chart — Members by Role -->
							<VBox styleClass="chart-card" HBox.hgrow="ALWAYS"
								spacing="4">
								<Label text="📊 Member Distribution"
									styleClass="chart-title-label" />
								<Label
									text="Number of students vs librarians registered"
									styleClass="card-subheader-label" />
								<BarChart fx:id="chartMemberRoles"
									prefHeight="280" maxWidth="Infinity"
									legendVisible="false" barGap="8"
									categoryGap="40">
									<xAxis>
										<CategoryAxis />
									</xAxis>
									<yAxis>
										<NumberAxis />
									</yAxis>
								</BarChart>
							</VBox>
						</HBox>

						<!-- Second Chart Row -->
						<HBox spacing="18">
							<!-- Bar Chart — Top 5 Most Borrowed Books -->
							<VBox styleClass="chart-card" HBox.hgrow="ALWAYS"
								spacing="4">
								<Label text="📈 Top Borrowed Books"
									styleClass="chart-title-label" />
								<Label text="Books with the most borrow records"
									styleClass="card-subheader-label" />
								<BarChart fx:id="chartTopBooks" prefHeight="260"
									maxWidth="Infinity"
									legendVisible="false" barGap="6"
									categoryGap="30">
									<xAxis>
										<CategoryAxis />
									</xAxis>
									<yAxis>
										<NumberAxis />
									</yAxis>
								</BarChart>
							</VBox>

							<!-- Pie Chart — Fine Status -->
							<VBox styleClass="chart-card" HBox.hgrow="ALWAYS"
								spacing="4">
								<Label text="💳 Fine Status Overview"
									styleClass="chart-title-label" />
								<Label
									text="Paid vs unpaid fines across all members"
									styleClass="card-subheader-label" />
								<PieChart fx:id="chartFineStatus"
									prefHeight="260" maxWidth="Infinity"
									legendVisible="true" labelsVisible="true" />
							</VBox>
						</HBox>
					</VBox>

					<!-- ─── ISSUE BOOK ─── -->
					<VBox fx:id="viewIssueBook" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="📋 Issue Book"
									styleClass="card-header-label" />
								<Label
									text="Find a student by email, then select a book to issue"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="18" style="-fx-padding:16 24 24 24;">
							<VBox styleClass="form-section" spacing="14">
								<Label text="FIND STUDENT"
									styleClass="sidebar-section-label"
									style="-fx-padding:0;" />
								<HBox spacing="14" alignment="BOTTOM_LEFT">
									<VBox spacing="4" prefWidth="340">
										<Label text="Student Email"
											styleClass="form-label" />
										<TextField fx:id="txtIssueStudentEmail"
											promptText="student@email.com" />
									</VBox>
									<Button text="🔍 Find"
										onAction="#findStudentForIssue"
										styleClass="btn-secondary"
										style="-fx-padding:10 22;" />
									<VBox spacing="4" HBox.hgrow="ALWAYS">
										<Label text="Student Found"
											styleClass="form-label" />
										<Label fx:id="lblIssueStudentName"
											text="—"
											style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#059669;" />
									</VBox>
								</HBox>
							</VBox>
							<TableView fx:id="tblIssueBooks" prefHeight="380"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="ID" prefWidth="70">
										<cellValueFactory>
											<PropertyValueFactory
												property="bookId" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Title" prefWidth="280">
										<cellValueFactory>
											<PropertyValueFactory
												property="title" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Author" prefWidth="200">
										<cellValueFactory>
											<PropertyValueFactory
												property="author" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Publisher"
										prefWidth="170">
										<cellValueFactory>
											<PropertyValueFactory
												property="publisher" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Available"
										prefWidth="100">
										<cellValueFactory>
											<PropertyValueFactory
												property="availableCopies" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
							<HBox alignment="CENTER_RIGHT" spacing="14">
								<Label fx:id="lblIssueStatus"
									styleClass="status-label-success" />
								<Button text="📋 Issue Selected Book"
									onAction="#issueBook"
									styleClass="btn-success" />
							</HBox>
						</VBox>
					</VBox>

					<!-- ─── BOOK MANAGEMENT ─── -->
					<VBox fx:id="viewBookManage" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="📚 Book Management"
									styleClass="card-header-label" />
								<Label
									text="Add, edit, or remove books from the library catalog"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="18" style="-fx-padding:16 24 24 24;">
							<VBox styleClass="form-section" spacing="14">
								<HBox alignment="CENTER_LEFT">
									<Label fx:id="lblBookFormTitle"
										text="ADD NEW BOOK"
										styleClass="sidebar-section-label"
										style="-fx-padding:0;" />
									<Region HBox.hgrow="ALWAYS" />
									<Button text="✕ Clear"
										onAction="#clearBookForm"
										styleClass="btn-secondary"
										style="-fx-font-size:11px;-fx-padding:5 14;" />
								</HBox>
								<HBox spacing="12" alignment="BOTTOM_LEFT">
									<VBox spacing="4" HBox.hgrow="ALWAYS">
										<Label text="Title *"
											styleClass="form-label" />
										<TextField fx:id="txtBookTitle"
											promptText="Book title" />
									</VBox>
									<VBox spacing="4" HBox.hgrow="ALWAYS">
										<Label text="Author *"
											styleClass="form-label" />
										<TextField fx:id="txtBookAuthor"
											promptText="Author name" />
									</VBox>
									<VBox spacing="4" prefWidth="160">
										<Label text="Publisher"
											styleClass="form-label" />
										<TextField fx:id="txtBookPub"
											promptText="Publisher" />
									</VBox>
									<VBox spacing="4" prefWidth="90">
										<Label text="Year *"
											styleClass="form-label" />
										<TextField fx:id="txtBookYear"
											promptText="YYYY" />
									</VBox>
									<VBox spacing="4" prefWidth="90">
										<Label text="Copies *"
											styleClass="form-label" />
										<TextField fx:id="txtBookCopies"
											promptText="0" />
									</VBox>
									<Button fx:id="btnBookSubmit"
										text="➕ Add Book"
										onAction="#addOrUpdateBook"
										styleClass="btn-success"
										style="-fx-padding:10 22;" />
								</HBox>
								<Label fx:id="lblBookStatus"
									styleClass="status-label-success" />
							</VBox>
							<TableView fx:id="tblBooks" prefHeight="400"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="ID" prefWidth="65">
										<cellValueFactory>
											<PropertyValueFactory
												property="bookId" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Title" prefWidth="240">
										<cellValueFactory>
											<PropertyValueFactory
												property="title" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Author" prefWidth="180">
										<cellValueFactory>
											<PropertyValueFactory
												property="author" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Publisher"
										prefWidth="160">
										<cellValueFactory>
											<PropertyValueFactory
												property="publisher" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Year" prefWidth="75">
										<cellValueFactory>
											<PropertyValueFactory
												property="publicationYear" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Total" prefWidth="75">
										<cellValueFactory>
											<PropertyValueFactory
												property="totalCopies" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Available" prefWidth="90">
										<cellValueFactory>
											<PropertyValueFactory
												property="availableCopies" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
							<HBox alignment="CENTER_RIGHT" spacing="12">
								<Button text="✏️ Edit Selected"
									onAction="#editSelectedBook"
									styleClass="btn-secondary" />
								<Button text="🗑 Delete Selected"
									onAction="#deleteBook"
									styleClass="btn-danger" />
							</HBox>
						</VBox>
					</VBox>

					<!-- ─── MEMBER MANAGEMENT ─── -->
					<VBox fx:id="viewMemberManage" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="👥 Member Management"
									styleClass="card-header-label" />
								<Label
									text="View all registered members and manage accounts"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="16" style="-fx-padding:16 24 24 24;">
							<TableView fx:id="tblMembers" prefHeight="520"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="User ID" prefWidth="90">
										<cellValueFactory>
											<PropertyValueFactory
												property="userId" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Name" prefWidth="220">
										<cellValueFactory>
											<PropertyValueFactory
												property="name" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Email" prefWidth="280">
										<cellValueFactory>
											<PropertyValueFactory
												property="email" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Phone" prefWidth="160">
										<cellValueFactory>
											<PropertyValueFactory
												property="phone" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Role" prefWidth="130">
										<cellValueFactory>
											<PropertyValueFactory
												property="role" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
							<HBox alignment="CENTER_RIGHT" spacing="12">
								<Label fx:id="lblMemberStatus"
									styleClass="status-label-error" />
								<Button text="🗑 Delete Selected"
									onAction="#deleteMember"
									styleClass="btn-danger" />
							</HBox>
						</VBox>
					</VBox>

					<!-- ─── NOTIFICATIONS ─── -->
					<VBox fx:id="viewNotifications" styleClass="card"
						managed="false" visible="false" spacing="0">
						<HBox
							style="-fx-padding:20 24 16 24;-fx-border-color:transparent transparent #e2e8f0 transparent;-fx-border-width:1;">
							<VBox spacing="2">
								<Label text="🔔 Notifications"
									styleClass="card-header-label" />
								<Label
									text="Compose and broadcast announcements to all members"
									styleClass="card-subheader-label" />
							</VBox>
						</HBox>
						<VBox spacing="18" style="-fx-padding:16 24 24 24;">
							<VBox styleClass="form-section" spacing="14">
								<Label text="COMPOSE"
									styleClass="sidebar-section-label"
									style="-fx-padding:0;" />
								<HBox spacing="14" alignment="BOTTOM_LEFT">
									<VBox spacing="4" prefWidth="220">
										<Label text="Type"
											styleClass="form-label" />
										<ComboBox fx:id="cmbNotifType"
											prefWidth="220" />
									</VBox>
									<VBox spacing="4" HBox.hgrow="ALWAYS">
										<Label text="Message"
											styleClass="form-label" />
										<TextField fx:id="txtNotifMessage"
											promptText="Enter notification message..." />
									</VBox>
									<Button text="🔔 Send"
										onAction="#sendNotification"
										styleClass="btn-primary"
										style="-fx-padding:10 28;" />
								</HBox>
								<Label fx:id="lblNotifStatus"
									styleClass="status-label-success" />
							</VBox>
							<TableView fx:id="tblNotifications" prefHeight="440"
								maxWidth="Infinity">
								<columns>
									<TableColumn text="Date / Time"
										prefWidth="200">
										<cellValueFactory>
											<PropertyValueFactory
												property="createdAt" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Type" prefWidth="160">
										<cellValueFactory>
											<PropertyValueFactory
												property="type" />
										</cellValueFactory>
									</TableColumn>
									<TableColumn text="Message" prefWidth="900">
										<cellValueFactory>
											<PropertyValueFactory
												property="message" />
										</cellValueFactory>
									</TableColumn>
								</columns>
							</TableView>
						</VBox>
					</VBox>

				</VBox>
			</ScrollPane>
		</VBox>
	</center>
</BorderPane>
